# MindCare Backend Configuration

# Flask Settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DB_PATH=mental_health.db
DB_TIMEOUT=30

# Model Configuration
MODEL_PATH=model.pkl
SCALER_PATH=scaler.pkl
DATASET_PATH=stress_dataset.csv

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Feature Limits (for validation)
MIN_SLEEP=0
MAX_SLEEP=24
MIN_SCREEN_TIME=0
MAX_SCREEN_TIME=24
MIN_WORKLOAD=0
MAX_WORKLOAD=24
MAX_MESSAGE_LENGTH=500

# Training Configuration
RANDOM_STATE=42
TEST_SIZE=0.2
CROSS_VAL_FOLDS=5
TRAINING_SAMPLES=200
